/-!
# First reductions for groups of order `36`

For a group `G` of order `36 = 4 * 3^2`, the number of Sylow `3`-subgroups is
`1` or `4`.

* If it is `1`, the Sylow `3`-subgroup is normal of order `9`, and Schur--Zassenhaus
  writes `G` as a semidirect product `N ‚čä H` with `|N| = 9` and `|H| = 4`.
* If it is `4`, the conjugation action on the four Sylow `3`-subgroups has kernel
  of order `3` and image the alternating group `A‚āĄ` after identifying the four
  Sylow subgroups with `Fin 4`.

These are the two structural branches used in the classification of groups of order `36`.
-/

namespace Smallgroups.UsefulTheorems

open Sylow Equiv.Perm Subgroup

variable {G : Type*} [Group G]

/-! ### Standard factors and representatives for the normal Sylow branch -/

/-- The cyclic group `C‚āā`. -/
abbrev order36_C2 : Type := CyclicRep 2

/-- The cyclic group `C‚āĄ`. -/
abbrev order36_C4 : Type := CyclicRep 4

/-- The Klein four group, written as `C‚āā √ó C‚āā`. -/
abbrev order36_V4 : Type := order36_C2 √ó order36_C2

/-- The cyclic group `C‚āČ`. -/
abbrev order36_C9 : Type := CyclicRep 9

/-- The elementary abelian group `C‚āÉ √ó C‚āÉ`. -/
abbrev order36_E9 : Type := ElemAbelianRep 3

/-- A `C‚āĄ` action generated by an automorphism whose fourth power is the identity. -/
noncomputable def order36_c4ActionOfAut {N : Type*} [Group N]
    (őĪ : MulAut N) (hőĪ : őĪ ^ 4 = 1) : order36_C4 ‚Üí* MulAut N :=
  MonoidHom.mk' (fun x => őĪ ^ (Multiplicative.toAdd x).val)
    (fun x y => pow_val_add hőĪ (Multiplicative.toAdd x) (Multiplicative.toAdd y))

private theorem order36_neg_one_pow_four_units :
    (-1 : (ZMod 9)ň£) ^ 4 = 1 := by
  rw [show (4 : ‚Ąē) = 2 * 2 by norm_num, pow_mul]
  simp [sq]

/-- The inversion action of `C‚āĄ` on `C‚āČ`, factoring through `C‚āā`. -/
noncomputable abbrev order36_C9_C4_invAction : order36_C4 ‚Üí* MulAut order36_C9 :=
  actionHom (-1 : (ZMod 9)ň£) order36_neg_one_pow_four_units

/-- The additive group underlying `C‚āÉ √ó C‚āÉ`. -/
abbrev order36_E9Add : Type := ZMod 3 √ó ZMod 3

/-- Negate both coordinates of `C‚āÉ √ó C‚āÉ`. -/
def order36_E9_negBothAddEquiv : order36_E9Add ‚ČÉ+ order36_E9Add where
  toFun x := (-x.1, -x.2)
  invFun x := (-x.1, -x.2)
  left_inv x := by ext <;> simp
  right_inv x := by ext <;> simp
  map_add' x y := by
    ext
    ¬∑ change -(x.1 + y.1) = -x.1 + -y.1
      abel
    ¬∑ change -(x.2 + y.2) = -x.2 + -y.2
      abel

/-- Negate the first coordinate of `C‚āÉ √ó C‚āÉ`. -/
def order36_E9_negFirstAddEquiv : order36_E9Add ‚ČÉ+ order36_E9Add where
  toFun x := (-x.1, x.2)
  invFun x := (-x.1, x.2)
  left_inv x := by ext <;> simp
  right_inv x := by ext <;> simp
  map_add' x y := by
    ext
    ¬∑ change -(x.1 + y.1) = -x.1 + -y.1
      abel
    ¬∑ change x.2 + y.2 = x.2 + y.2
      rfl

/-- An order-four rotation of `C‚āÉ √ó C‚āÉ`: `(x, y) ‚Ü¶ (-y, x)`. -/
def order36_E9_rotAddEquiv : order36_E9Add ‚ČÉ+ order36_E9Add where
  toFun x := (-x.2, x.1)
  invFun x := (x.2, -x.1)
  left_inv x := by ext <;> simp
  right_inv x := by ext <;> simp
  map_add' x y := by
    ext
    ¬∑ change -(x.2 + y.2) = -x.2 + -y.2
      abel
    ¬∑ change x.1 + y.1 = x.1 + y.1
      rfl

/-- The automorphism `-I` of `C‚āÉ √ó C‚āÉ`. -/
def order36_E9_negBothAut : MulAut order36_E9 :=
  AddEquiv.toMultiplicative order36_E9_negBothAddEquiv

/-- The reflection automorphism `(x, y) ‚Ü¶ (-x, y)` of `C‚āÉ √ó C‚āÉ`. -/
def order36_E9_negFirstAut : MulAut order36_E9 :=
  AddEquiv.toMultiplicative order36_E9_negFirstAddEquiv

/-- The order-four automorphism `(x, y) ‚Ü¶ (-y, x)` of `C‚āÉ √ó C‚āÉ`. -/
def order36_E9_rotAut : MulAut order36_E9 :=
  AddEquiv.toMultiplicative order36_E9_rotAddEquiv

theorem order36_E9_negBothAut_pow_four : order36_E9_negBothAut ^ 4 = 1 := by
  ext x <;> fin_cases x <;> decide

theorem order36_E9_negFirstAut_pow_four : order36_E9_negFirstAut ^ 4 = 1 := by
  ext x <;> fin_cases x <;> decide

theorem order36_E9_rotAut_pow_four : order36_E9_rotAut ^ 4 = 1 := by
  ext x <;> fin_cases x <;> decide

/-- `C‚āÉ √ó C‚āÉ` with a `C‚āĄ` action by `-I`. -/
noncomputable abbrev order36_E9_C4_negBothAction : order36_C4 ‚Üí* MulAut order36_E9 :=
  order36_c4ActionOfAut order36_E9_negBothAut order36_E9_negBothAut_pow_four

/-- `C‚āÉ √ó C‚āÉ` with a `C‚āĄ` action by a reflection. -/
noncomputable abbrev order36_E9_C4_negFirstAction : order36_C4 ‚Üí* MulAut order36_E9 :=
  order36_c4ActionOfAut order36_E9_negFirstAut order36_E9_negFirstAut_pow_four

/-- `C‚āÉ √ó C‚āÉ` with a faithful `C‚āĄ` action. -/
noncomputable abbrev order36_E9_C4_rotAction : order36_C4 ‚Üí* MulAut order36_E9 :=
  order36_c4ActionOfAut order36_E9_rotAut order36_E9_rotAut_pow_four

/-- The twelve representatives arising from the normal Sylow-`3` branch of order `36`. -/
noncomputable def order36_normal_reps : Fin 12 ‚Üí Type
  | 0 => order36_C9 √ó order36_C4
  | 1 => SemidirectProduct order36_C9 order36_C4 order36_C9_C4_invAction
  | 2 => order36_C9 √ó order36_V4
  | 3 => DihedralGroup 9 √ó order36_C2
  | 4 => order36_E9 √ó order36_C4
  | 5 => SemidirectProduct order36_E9 order36_C4 order36_E9_C4_negBothAction
  | 6 => SemidirectProduct order36_E9 order36_C4 order36_E9_C4_negFirstAction
  | 7 => SemidirectProduct order36_E9 order36_C4 order36_E9_C4_rotAction
  | 8 => order36_E9 √ó order36_V4
  | 9 => SemidirectProduct order36_E9 order36_C2 (invActionHom order36_E9) √ó order36_C2
  | 10 => DihedralGroup 3 √ó CyclicRep 3 √ó order36_C2
  | 11 => DihedralGroup 3 √ó DihedralGroup 3

noncomputable instance order36_normal_reps_group : ‚ąÄ i, Group (order36_normal_reps i)
  | 0 => by dsimp [order36_normal_reps]; infer_instance
  | 1 => by dsimp [order36_normal_reps]; infer_instance
  | 2 => by dsimp [order36_normal_reps]; infer_instance
  | 3 => by dsimp [order36_normal_reps]; infer_instance
  | 4 => by dsimp [order36_normal_reps]; infer_instance
  | 5 => by dsimp [order36_normal_reps]; infer_instance
  | 6 => by dsimp [order36_normal_reps]; infer_instance
  | 7 => by dsimp [order36_normal_reps]; infer_instance
  | 8 => by dsimp [order36_normal_reps]; infer_instance
  | 9 => by dsimp [order36_normal_reps]; infer_instance
  | 10 => by dsimp [order36_normal_reps]; infer_instance
  | 11 => by dsimp [order36_normal_reps]; infer_instance

/-- Every representative in the normal Sylow-`3` branch has order `36`. -/
theorem card_order36_normal_reps (i : Fin 12) : Nat.card (order36_normal_reps i) = 36 := by
  fin_cases i <;>
    simp [order36_normal_reps, SemidirectProduct.card, Nat.card_prod, DihedralGroup.card]

/-! ### Sylow `3` counting and the normal Sylow branch -/

/-- In a group of order `36`, the number of Sylow `3`-subgroups is `1` or `4`. -/
theorem card_sylow_3_eq_one_or_four_of_card_36 [Finite G] (hG : Nat.card G = 36) :
    Nat.card (Sylow 3 G) = 1 ‚ą® Nat.card (Sylow 3 G) = 4 := by
  haveI : Fact (Nat.Prime 3) := ‚ü®by norm_num‚ü©
  obtain ‚ü®P0‚ü© := (Sylow.nonempty : Nonempty (Sylow 3 G))
  have hdvd36 : Nat.card (Sylow 3 G) ‚ą£ 36 := by
    rw [‚Üź hG]
    exact P0.card_dvd_index.trans (Subgroup.index_dvd_card _)
  have hndvd : ¬¨ 3 ‚ą£ Nat.card (Sylow 3 G) := not_dvd_card_sylow 3 G
  have hcop : Nat.Coprime (Nat.card (Sylow 3 G)) (3 ^ 2) :=
    ((Nat.prime_three.coprime_iff_not_dvd.mpr hndvd).symm).pow_right 2
  have hdvd4_mul : Nat.card (Sylow 3 G) ‚ą£ 4 * 3 ^ 2 := by
    simpa [show 36 = 4 * 3 ^ 2 by norm_num] using hdvd36
  have hdvd4 : Nat.card (Sylow 3 G) ‚ą£ 4 :=
    hcop.dvd_of_dvd_mul_right hdvd4_mul
  have hmod := card_sylow_modEq_one 3 G
  have hle : Nat.card (Sylow 3 G) ‚Č§ 4 := Nat.le_of_dvd (by norm_num) hdvd4
  have hpos : 0 < Nat.card (Sylow 3 G) := Nat.card_pos
  interval_cases h : Nat.card (Sylow 3 G)
  ¬∑ left
    rfl
  ¬∑ unfold Nat.ModEq at hmod
    omega
  ¬∑ norm_num at hdvd4
  ¬∑ right
    rfl

/-- A Sylow `3`-subgroup of a group of order `36` has order `9`. -/
theorem card_sylow_3_subgroup_of_card_36 [Finite G] (hG : Nat.card G = 36)
    (P : Sylow 3 G) : Nat.card (‚ÜĎP : Subgroup G) = 9 := by
  haveI : Fact (Nat.Prime 3) := ‚ü®by norm_num‚ü©
  have hfact : (36 : ‚Ąē).factorization 3 = 2 := by
    rw [show 36 = 4 * 3 ^ 2 by norm_num,
      Nat.factorization_mul (by norm_num) (by norm_num), Finsupp.add_apply,
      Nat.factorization_eq_zero_of_not_dvd (by norm_num : ¬¨ (3 : ‚Ąē) ‚ą£ 4),
      Nat.factorization_pow_self (by norm_num : Nat.Prime 3), zero_add]
  rw [Sylow.card_eq_multiplicity, hG, hfact]
  norm_num

/-- If there is a unique Sylow `3`-subgroup in a group of order `36`, it is normal. -/
theorem sylow_3_normal_of_card_36_of_card_sylow_eq_one [Finite G]
    (hSyl : Nat.card (Sylow 3 G) = 1) (P : Sylow 3 G) :
    (‚ÜĎP : Subgroup G).Normal := by
  haveI : Fact (Nat.Prime 3) := ‚ü®by norm_num‚ü©
  haveI : Subsingleton (Sylow 3 G) := (Nat.card_eq_one_iff_unique.mp hSyl).1
  exact normal_of_subsingleton P

/-- **Schur--Zassenhaus reduction for the normal Sylow-`3` branch of order `36`.** -/
theorem order36_semidirectProduct_of_card_sylow_3_eq_one [Finite G] (hG : Nat.card G = 36)
    (hSyl : Nat.card (Sylow 3 G) = 1) :
    ‚ąÉ (N H : Subgroup G) (ŌÜ : H ‚Üí* MulAut N),
      N.Normal ‚ąß Nat.card N = 9 ‚ąß Nat.card H = 4 ‚ąß
        Nonempty (G ‚ČÉ* SemidirectProduct N H ŌÜ) := by
  haveI : Fact (Nat.Prime 3) := ‚ü®by norm_num‚ü©
  obtain ‚ü®P0‚ü© := (Sylow.nonempty : Nonempty (Sylow 3 G))
  haveI hnorm : (‚ÜĎP0 : Subgroup G).Normal :=
    sylow_3_normal_of_card_36_of_card_sylow_eq_one hSyl P0
  have hcardN : Nat.card (‚ÜĎP0 : Subgroup G) = 9 :=
    card_sylow_3_subgroup_of_card_36 hG P0
  haveI : (‚ÜĎP0 : Subgroup G).FiniteIndex := ‚ü®Subgroup.index_ne_zero_of_finite‚ü©
  have hcop : Nat.Coprime (Nat.card (‚ÜĎP0 : Subgroup G)) (‚ÜĎP0 : Subgroup G).index := by
    rw [hcardN]
    have hidx : (‚ÜĎP0 : Subgroup G).index = 4 := by
      have := (‚ÜĎP0 : Subgroup G).card_mul_index
      rw [hcardN, hG] at this
      omega
    rw [hidx]
    norm_num
  obtain ‚ü®H, ŌÜ, ‚ü®e‚ü©‚ü© := schurZassenhaus_semidirectProduct (‚ÜĎP0 : Subgroup G) hcop
  have hcardH : Nat.card H = 4 := by
    have h1 : Nat.card G = Nat.card (‚ÜĎP0 : Subgroup G) * Nat.card H := by
      rw [Nat.card_congr e.toEquiv, Nat.card_congr SemidirectProduct.equivProd, Nat.card_prod]
    rw [hG, hcardN] at h1
    have h1' : 9 * Nat.card H = 9 * 4 := by omega
    exact Nat.eq_of_mul_eq_mul_left (by norm_num : 0 < 9) h1'
  exact ‚ü®‚ÜĎP0, H, ŌÜ, hnorm, hcardN, hcardH, ‚ü®e‚ü©‚ü©

/-! ### The non-normal Sylow branch -/

/-- If there are four Sylow `3`-subgroups, each Sylow `3`-subgroup is self-normalizing. -/
theorem sylow_3_eq_normalizer_of_card_36_of_card_sylow_3_eq_four [Finite G]
    (hG : Nat.card G = 36) (hSyl : Nat.card (Sylow 3 G) = 4) (P : Sylow 3 G) :
    (‚ÜĎP : Subgroup G) = Subgroup.normalizer (P : Set G) := by
  haveI : Fact (Nat.Prime 3) := ‚ü®by norm_num‚ü©
  have hcardP : Nat.card (‚ÜĎP : Subgroup G) = 9 :=
    card_sylow_3_subgroup_of_card_36 hG P
  have hidx : (Subgroup.normalizer (P : Set G)).index = 4 := by
    rwa [‚Üź Sylow.card_eq_index_normalizer P]
  have hcardNorm : Nat.card (Subgroup.normalizer (P : Set G)) = 9 := by
    have := (Subgroup.normalizer (P : Set G)).card_mul_index
    rw [hidx, hG] at this
    omega
  exact Subgroup.eq_of_le_of_card_ge Subgroup.le_normalizer (by rw [hcardNorm, hcardP])

/-- In the non-normal Sylow-`3` branch of order `36`, the conjugation action on the four
Sylow `3`-subgroups has kernel of order `3` and image `A‚āĄ`, after the Sylow subgroups are
identified with `Fin 4`. -/
theorem order36_sylow_3_conj_action_A4_of_card_sylow_3_eq_four [Finite G]
    (hG : Nat.card G = 36) (hSyl : Nat.card (Sylow 3 G) = 4) :
    ‚ąÉ Ōą : G ‚Üí* Equiv.Perm (Fin 4),
      Nat.card Ōą.ker = 3 ‚ąß Ōą.range = alternatingGroup (Fin 4) := by
  haveI : Fact (Nat.Prime 3) := ‚ü®by norm_num‚ü©
  haveI : Fintype (Sylow 3 G) := Fintype.ofFinite _
  have hfincard : Fintype.card (Sylow 3 G) = 4 := by
    rwa [‚Üź Nat.card_eq_fintype_card]
  let őĶ : Sylow 3 G ‚ČÉ Fin 4 := by rw [‚Üź hfincard]; exact Fintype.equivFin _
  let ŌÜ := MulAction.toPermHom G (Sylow 3 G)
  let Ōą : G ‚Üí* Equiv.Perm (Fin 4) :=
    (Equiv.permCongrHom őĶ).toMonoidHom.comp ŌÜ
  obtain ‚ü®P0‚ü© := (Sylow.nonempty : Nonempty (Sylow 3 G))
  have hP_eq_norm :
      (‚ÜĎP0 : Subgroup G) = Subgroup.normalizer (P0 : Set G) :=
    sylow_3_eq_normalizer_of_card_36_of_card_sylow_3_eq_four hG hSyl P0
  have hker_le : Ōą.ker ‚Č§ ‚ÜĎP0 := by
    intro g hg
    rw [hP_eq_norm]
    have hgŌą := MonoidHom.mem_ker.mp hg
    have hgŌÜ : ŌÜ g = 1 := by
      have hgŌÜ' : őĶ.permCongr (ŌÜ g) = 1 := by
        change Ōą g = 1 at hgŌą
        exact hgŌą
      have hgŌÜ'' : őĶ.permCongr (ŌÜ g) = őĶ.permCongr 1 := by
        have h_one : őĶ.permCongr 1 = (1 : Equiv.Perm (Fin 4)) := by
          ext x
          simp [Equiv.permCongr_apply]
        rw [h_one]
        exact hgŌÜ'
      exact őĶ.permCongr.injective hgŌÜ''
    rw [‚Üź Sylow.stabilizer_eq_normalizer]
    rw [MulAction.mem_stabilizer_iff]
    exact Equiv.Perm.ext_iff.mp hgŌÜ P0
  have hcardP : Nat.card (‚ÜĎP0 : Subgroup G) = 9 :=
    card_sylow_3_subgroup_of_card_36 hG P0
  have hker_card_dvd : Nat.card Ōą.ker ‚ą£ Nat.card (‚ÜĎP0 : Subgroup G) :=
    Subgroup.card_dvd_of_le hker_le
  rw [hcardP] at hker_card_dvd
  have hker_card_ne_nine : Nat.card Ōą.ker ‚Č† 9 := by
    intro hker_card
    have hker_eq : Ōą.ker = ‚ÜĎP0 :=
      Subgroup.eq_of_le_of_card_ge hker_le (by rw [hcardP, hker_card])
    haveI : (‚ÜĎP0 : Subgroup G).Normal := hker_eq ‚Ėł MonoidHom.normal_ker Ōą
    haveI := Sylow.unique_of_normal P0 (by assumption)
    have : Nat.card (Sylow 3 G) = 1 := Nat.card_unique
    omega
  have hker_card_ne_one : Nat.card Ōą.ker ‚Č† 1 := by
    intro hker_card
    have hker_bot : Ōą.ker = ‚ä• := Ōą.ker.eq_bot_of_card_eq hker_card
    have hŌą_inj : Function.Injective Ōą := Ōą.ker_eq_bot_iff.mp hker_bot
    have e_range : G ‚ČÉ* Ōą.range := MonoidHom.ofInjective hŌą_inj
    have h_range_card : Nat.card Ōą.range = 36 := by
      rw [‚Üź hG, Nat.card_congr e_range.toEquiv]
    have h_perm_card : Nat.card (Equiv.Perm (Fin 4)) = 24 := by
      rw [Nat.card_perm, Nat.card_fin]
      decide
    have h_dvd : Nat.card Ōą.range ‚ą£ Nat.card (Equiv.Perm (Fin 4)) :=
      Subgroup.card_subgroup_dvd_card Ōą.range
    rw [h_range_card, h_perm_card] at h_dvd
    norm_num at h_dvd
  have hker_card : Nat.card Ōą.ker = 3 := by
    have hcases : Nat.card Ōą.ker = 1 ‚ą® Nat.card Ōą.ker = 3 ‚ą® Nat.card Ōą.ker = 9 := by
      have hle : Nat.card Ōą.ker ‚Č§ 9 := Nat.le_of_dvd (by norm_num) hker_card_dvd
      have hpos : 0 < Nat.card Ōą.ker := Nat.card_pos
      interval_cases h : Nat.card Ōą.ker
      ¬∑ left
        rfl
      ¬∑ exfalso
        norm_num [h] at hker_card_dvd
      ¬∑ right
        left
        rfl
      ¬∑ exfalso
        norm_num [h] at hker_card_dvd
      ¬∑ exfalso
        norm_num [h] at hker_card_dvd
      ¬∑ exfalso
        norm_num [h] at hker_card_dvd
      ¬∑ exfalso
        norm_num [h] at hker_card_dvd
      ¬∑ exfalso
        norm_num [h] at hker_card_dvd
      ¬∑ right
        right
        rfl
    rcases hcases with h | h | h
    ¬∑ exact absurd h hker_card_ne_one
    ¬∑ exact h
    ¬∑ exact absurd h hker_card_ne_nine
  have h_range_card : Nat.card Ōą.range = 12 := by
    have hidx : Ōą.ker.index = 12 := by
      have := Ōą.ker.card_mul_index
      rw [hker_card, hG] at this
      omega
    rwa [‚Üź Subgroup.index_ker Ōą]
  have h_perm_card : Nat.card (Equiv.Perm (Fin 4)) = 24 := by
    rw [Nat.card_perm, Nat.card_fin]
    decide
  have h_range_idx : Ōą.range.index = 2 := by
    have := Ōą.range.card_mul_index
    rw [h_range_card, h_perm_card] at this
    omega
  have h_alt : Ōą.range = alternatingGroup (Fin 4) :=
    Equiv.Perm.eq_alternatingGroup_of_index_eq_two h_range_idx
  exact ‚ü®Ōą, hker_card, h_alt‚ü©

/-- In the non-normal Sylow-`3` branch of order `36`, there is a normal subgroup of order `3`
whose quotient is `A‚āĄ`. -/
theorem order36_has_normal_order_three_and_A4_quotient_of_card_sylow_3_eq_four [Finite G]
    (hG : Nat.card G = 36) (hSyl : Nat.card (Sylow 3 G) = 4) :
    ‚ąÉ (K : Subgroup G) (_ : K.Normal), Nat.card K = 3 ‚ąß
      Nonempty (G ‚ßł K ‚ČÉ* alternatingGroup (Fin 4)) := by
  obtain ‚ü®Ōą, hker_card, h_alt‚ü© :=
    order36_sylow_3_conj_action_A4_of_card_sylow_3_eq_four (G := G) hG hSyl
  exact ‚ü®Ōą.ker, MonoidHom.normal_ker Ōą, hker_card,
    ‚ü®(QuotientGroup.quotientKerEquivRange Ōą).trans (MulEquiv.subgroupCongr h_alt)‚ü©‚ü©

end Smallgroups.UsefulTheorems
