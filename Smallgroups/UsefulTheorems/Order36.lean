    haveI : Fact (Nat.Prime 3) := ‚ü®by norm_num‚ü©
    dsimp
    ext <;> simp only [toAdd_ofAdd]
    ¬∑ calc
        (a * d - b * c)‚ĀĽ¬Ļ * (d * (a * Multiplicative.toAdd x.1 + b * Multiplicative.toAdd x.2) -
            b * (c * Multiplicative.toAdd x.1 + d * Multiplicative.toAdd x.2))
            = ((a * d - b * c)‚ĀĽ¬Ļ * (a * d - b * c)) * Multiplicative.toAdd x.1 := by ring
        _ = Multiplicative.toAdd x.1 := by
          rw [show (a * d - b * c)‚ĀĽ¬Ļ * (a * d - b * c) = 1 by
            exact inv_mul_cancel‚āÄ (a := a * d - b * c) (by simpa using hdet)]
          ring
    ¬∑ calc
        (a * d - b * c)‚ĀĽ¬Ļ * (-c * (a * Multiplicative.toAdd x.1 + b * Multiplicative.toAdd x.2) +
            a * (c * Multiplicative.toAdd x.1 + d * Multiplicative.toAdd x.2))
            = ((a * d - b * c)‚ĀĽ¬Ļ * (a * d - b * c)) * Multiplicative.toAdd x.2 := by ring
        _ = Multiplicative.toAdd x.2 := by
          rw [show (a * d - b * c)‚ĀĽ¬Ļ * (a * d - b * c) = 1 by
            exact inv_mul_cancel‚āÄ (a := a * d - b * c) (by simpa using hdet)]
          ring
  right_inv x := by
    haveI : Fact (Nat.Prime 3) := ‚ü®by norm_num‚ü©
    dsimp
    ext
    ¬∑ calc
        a * ((a * d - b * c)‚ĀĽ¬Ļ * (d * Multiplicative.toAdd x.1 - b * Multiplicative.toAdd x.2)) +
            b * ((a * d - b * c)‚ĀĽ¬Ļ * (-c * Multiplicative.toAdd x.1 + a * Multiplicative.toAdd x.2))
            = ((a * d - b * c) * (a * d - b * c)‚ĀĽ¬Ļ) * Multiplicative.toAdd x.1 := by ring
        _ = Multiplicative.toAdd x.1 := by
          rw [show (a * d - b * c) * (a * d - b * c)‚ĀĽ¬Ļ = 1 by
            exact mul_inv_cancel‚āÄ (a := a * d - b * c) (by simpa using hdet)]
          ring
    ¬∑ calc
        c * ((a * d - b * c)‚ĀĽ¬Ļ * (d * Multiplicative.toAdd x.1 - b * Multiplicative.toAdd x.2)) +
            d * ((a * d - b * c)‚ĀĽ¬Ļ * (-c * Multiplicative.toAdd x.1 + a * Multiplicative.toAdd x.2))
            = ((a * d - b * c) * (a * d - b * c)‚ĀĽ¬Ļ) * Multiplicative.toAdd x.2 := by ring
        _ = Multiplicative.toAdd x.2 := by
          rw [show (a * d - b * c) * (a * d - b * c)‚ĀĽ¬Ļ = 1 by
            exact mul_inv_cancel‚āÄ (a := a * d - b * c) (by simpa using hdet)]
