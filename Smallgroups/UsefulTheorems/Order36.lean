        simpa [a, b] using hq
      have hs' :
          (α order36_E9_e1).2.toAdd * q + (α order36_E9_e2).2.toAdd * s = s := by
        simpa [c, d] using hs
      rw [order36_E9_matrixAut_e2]
      rw [order36_E9_mulAut_apply_matrix]
      rw [order36_E9_negFirstAut_e2, order36_E9_matrixAut_e2]
