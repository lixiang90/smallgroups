theorem order36_E9_mulAut_pow_two_comm_negFirst_cases
    (β : MulAut order36_E9) (hβ : β ^ 2 = 1)
    (hcomm : order36_E9_negFirstAut * β = β * order36_E9_negFirstAut) :
    β = 1 ∨ β = order36_E9_negBothAut ∨ β = order36_E9_negFirstAut ∨
