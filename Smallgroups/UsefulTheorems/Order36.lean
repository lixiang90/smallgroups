/-!
# First reductions for groups of order `36`

For a group `G` of order `36 = 4 * 3^2`, the number of Sylow `3`-subgroups is
`1` or `4`.

* If it is `1`, the Sylow `3`-subgroup is normal of order `9`, and Schur--Zassenhaus
  writes `G` as a semidirect product `N ‚čä H` with `|N| = 9` and `|H| = 4`.
* If it is `4`, the conjugation action on the four Sylow `3`-subgroups has kernel
  of order `3` and image the alternating group `A‚āĄ` after identifying the four
  Sylow subgroups with `Fin 4`.

These are the two structural branches used in the classification of groups of order `36`.
-/

namespace Smallgroups.UsefulTheorems

open Sylow Equiv.Perm Subgroup

variable {G : Type*} [Group G]

/-! ### Standard factors and representatives for the normal Sylow branch -/

/-- The cyclic group `C‚āā`. -/
abbrev order36_C2 : Type := CyclicRep 2

/-- The cyclic group `C‚āĄ`. -/
abbrev order36_C4 : Type := CyclicRep 4

/-- The Klein four group, written as `C‚āā √ó C‚āā`. -/
abbrev order36_V4 : Type := order36_C2 √ó order36_C2

/-- The cyclic group `C‚āČ`. -/
abbrev order36_C9 : Type := CyclicRep 9

/-- The elementary abelian group `C‚āÉ √ó C‚āÉ`. -/
abbrev order36_E9 : Type := ElemAbelianRep 3

/-- A `C‚āā` action generated by an involutive automorphism. -/
noncomputable def order36_c2ActionOfAut {N : Type*} [Group N]
    (őĪ : MulAut N) (hőĪ : őĪ ^ 2 = 1) : order36_C2 ‚Üí* MulAut N :=
  MonoidHom.mk' (fun x => őĪ ^ (Multiplicative.toAdd x).val)
    (fun x y => pow_val_add hőĪ (Multiplicative.toAdd x) (Multiplicative.toAdd y))

/-- A `C‚āĄ` action generated by an automorphism whose fourth power is the identity. -/
noncomputable def order36_c4ActionOfAut {N : Type*} [Group N]
    (őĪ : MulAut N) (hőĪ : őĪ ^ 4 = 1) : order36_C4 ‚Üí* MulAut N :=
  MonoidHom.mk' (fun x => őĪ ^ (Multiplicative.toAdd x).val)
    (fun x y => pow_val_add hőĪ (Multiplicative.toAdd x) (Multiplicative.toAdd y))

private theorem order36_neg_one_pow_four_units :
    (-1 : (ZMod 9)ň£) ^ 4 = 1 := by
  rw [show (4 : ‚Ąē) = 2 * 2 by norm_num, pow_mul]
  simp [sq]

/-- Multiplication by units embeds into the automorphism group of `C‚āČ`. -/
theorem order36_unitAutHom_injective : Function.Injective (unitAutHom (p := 9)) := by
  intro u v h
  have h1 : unitAutHom u (Multiplicative.ofAdd (1 : ZMod 9)) =
      unitAutHom v (Multiplicative.ofAdd (1 : ZMod 9)) := by rw [h]
  simp only [unitAutHom_apply, mul_one, EmbeddingLike.apply_eq_iff_eq] at h1
  exact Units.ext (congrArg Multiplicative.toAdd h1)

/-- Every automorphism of `C‚āČ` is multiplication by a unit of `ZMod 9`. -/
theorem order36_mulAut_c9_eq_unitAutHom (ŌÉ : MulAut order36_C9) :
    ‚ąÉ u : (ZMod 9)ň£, ŌÉ = unitAutHom u := by
  let f : AddAut (ZMod 9) := Multiplicative.toAdd ((MulAutMultiplicative (ZMod 9)) ŌÉ)
  let u : (ZMod 9)ň£ := Additive.toMul ((ZMod.AddAutEquivUnits 9) f)
  refine ‚ü®u, ?_‚ü©
  ext x
  obtain ‚ü®m, rfl‚ü© := Multiplicative.ofAdd.surjective x
  change Multiplicative.ofAdd (f m) = unitAutHom u (Multiplicative.ofAdd m)
  have hu : Additive.ofMul u = (ZMod.AddAutEquivUnits 9) f := by simp [u]
  have hf : f = (ZMod.AddAutEquivUnits 9).symm (Additive.ofMul u) := by
    symm
    rw [hu]
    exact AddEquiv.symm_apply_apply (ZMod.AddAutEquivUnits 9) f
  rw [hf, unitAutHom_apply]
  simp [ZMod.AddAutEquivUnits_symm_apply, Units.smul_def]

/-- A unit of `ZMod 9` whose fourth power is `1` is `1` or `-1`. -/
theorem order36_unit_pow_four_eq_one_cases (u : (ZMod 9)ň£) (_hu : u ^ 4 = 1) :
    u = 1 ‚ą® u = -1 := by
  decide +revert

/-- A unit of `ZMod 9` whose square is `1` is `1` or `-1`. -/
theorem order36_unit_sq_eq_one_cases (u : (ZMod 9)ň£) (_hu : u ^ 2 = 1) :
    u = 1 ‚ą® u = -1 := by
  decide +revert

/-- Turn a unit-valued character into the corresponding action on `C‚āČ`. -/
noncomputable abbrev order36_c9Action {H : Type*} [Group H] (Ōá : H ‚Üí* (ZMod 9)ň£) :
    H ‚Üí* MulAut order36_C9 :=
  unitAutHom.comp Ōá

theorem order36_c9Action_one {H : Type*} [Group H] :
    order36_c9Action (H := H) 1 = 1 := by
  ext h x
  simp [order36_c9Action]

/-- If a product of acting groups acts only through the first factor, split off the second
factor. -/
noncomputable def semidirectProductActingProdFst {N H K : Type*} [Group N] [Group H] [Group K]
    (Ōą : H ‚Üí* MulAut N) :
    SemidirectProduct N (H √ó K) (Ōą.comp (MonoidHom.fst H K)) ‚ČÉ*
      SemidirectProduct N H Ōą √ó K where
  toFun x := (‚ü®x.left, x.right.1‚ü©, x.right.2)
  invFun x := ‚ü®x.1.left, (x.1.right, x.2)‚ü©
  left_inv x := by
    cases x
    rfl
  right_inv x := by
    cases x with
    | mk x1 x2 =>
      cases x1
      rfl
  map_mul' x y := by
    rfl

noncomputable def order36_c9Action_precomp_mulEquiv {H : Type*} [Group H]
    (Ōá : H ‚Üí* (ZMod 9)ň£) (ŌÉ : H ‚ČÉ* H) :
    SemidirectProduct order36_C9 H (order36_c9Action (Ōá.comp ŌÉ.toMonoidHom)) ‚ČÉ*
      SemidirectProduct order36_C9 H (order36_c9Action Ōá) :=
  semidirectProductCongrAut (N := order36_C9) (H := H) (ŌÜ := order36_c9Action Ōá) ŌÉ

noncomputable def order36_c9Action_precomp_eq_mulEquiv {H : Type*} [Group H]
    (Ōá Ōą : H ‚Üí* (ZMod 9)ň£) (ŌÉ : H ‚ČÉ* H)
    (h : Ōá.comp ŌÉ.toMonoidHom = Ōą) :
    SemidirectProduct order36_C9 H (order36_c9Action Ōą) ‚ČÉ*
      SemidirectProduct order36_C9 H (order36_c9Action Ōá) := by
  have haction : order36_c9Action Ōą = order36_c9Action (Ōá.comp ŌÉ.toMonoidHom) := by
    rw [h]
  exact (semidirectProductCongr_eq haction).trans
    (order36_c9Action_precomp_mulEquiv Ōá ŌÉ)

/-- The non-trivial `C‚āĄ` character with image generated by `-1`. -/
noncomputable abbrev order36_chiC4_inv : order36_C4 ‚Üí* (ZMod 9)ň£ :=
  powHom (p := 9) (q := 4) (-1 : (ZMod 9)ň£) order36_neg_one_pow_four_units

@[simp]
theorem order36_chiC4_inv_gen :
    order36_chiC4_inv (Multiplicative.ofAdd (1 : ZMod 4)) = (-1 : (ZMod 9)ň£) := by
  change (-1 : (ZMod 9)ň£) ^ (1 : ZMod 4).val = -1
  rw [show (1 : ZMod 4).val = 1 by decide]
  simp

/-- Homomorphisms out of `C‚āĄ` are determined by the additive generator `1`. -/
theorem order36_c4_hom_ext {M : Type*} [Group M] {Ōá Ōą : order36_C4 ‚Üí* M}
    (hgen : Ōá (Multiplicative.ofAdd (1 : ZMod 4)) =
      Ōą (Multiplicative.ofAdd (1 : ZMod 4))) :
    Ōá = Ōą := by
  apply MonoidHom.ext
  intro x
  let n : ZMod 4 := Multiplicative.toAdd x
  have hx : x = (Multiplicative.ofAdd (1 : ZMod 4)) ^ n.val := by
    rw [show x = Multiplicative.ofAdd n from (ofAdd_toAdd _).symm]
    calc
      Multiplicative.ofAdd n = Multiplicative.ofAdd ((n.val : ZMod 4)) := by
        rw [ZMod.natCast_zmod_val]
      _ = Multiplicative.ofAdd (n.val ‚ÄĘ (1 : ZMod 4)) := by simp
      _ = (Multiplicative.ofAdd (1 : ZMod 4)) ^ n.val := by rw [ofAdd_nsmul]
  rw [hx, map_pow, map_pow, hgen]

theorem order36_c4_unit_character_cases (Ōá : order36_C4 ‚Üí* (ZMod 9)ň£) :
    Ōá = 1 ‚ą® Ōá = order36_chiC4_inv := by
  let g : order36_C4 := Multiplicative.ofAdd (1 : ZMod 4)
  have hpow : Ōá g ^ 4 = 1 := by
    rw [‚Üź map_pow, show g ^ 4 = 1 by decide, map_one]
  rcases order36_unit_pow_four_eq_one_cases (Ōá g) hpow with h | h
  ¬∑ left
    apply order36_c4_hom_ext
    simp [g, h]
  ¬∑ right
    apply order36_c4_hom_ext
    rw [h, order36_chiC4_inv_gen]

/-- Every action `C‚āĄ ‚Üí Aut(C‚āČ)` is induced by a unit-valued character. -/
theorem order36_c4_c9Action_eq (ŌÜ : order36_C4 ‚Üí* MulAut order36_C9) :
    ‚ąÉ Ōá : order36_C4 ‚Üí* (ZMod 9)ň£, ŌÜ = order36_c9Action Ōá := by
  let g : order36_C4 := Multiplicative.ofAdd (1 : ZMod 4)
  obtain ‚ü®u, huŌÜ‚ü© := order36_mulAut_c9_eq_unitAutHom (ŌÜ g)
  have hg4 : g ^ 4 = 1 := by decide
  have hŌÜg4 : (ŌÜ g) ^ 4 = 1 := by rw [‚Üź map_pow, hg4, map_one]
  have hu4 : u ^ 4 = 1 := by
    apply order36_unitAutHom_injective
    rw [map_pow, ‚Üź huŌÜ, hŌÜg4]
    exact (map_one (unitAutHom (p := 9))).symm
  refine ‚ü®powHom (p := 9) (q := 4) u hu4, ?_‚ü©
  apply order36_c4_hom_ext
  rw [huŌÜ]
  change unitAutHom u = unitAutHom (u ^ (1 : ZMod 4).val)
  rw [show (1 : ZMod 4).val = 1 by decide]
  simp

theorem order36_c4_c9Action_cases (ŌÜ : order36_C4 ‚Üí* MulAut order36_C9) :
    ŌÜ = 1 ‚ą® ŌÜ = order36_c9Action order36_chiC4_inv := by
  obtain ‚ü®Ōá, hŌÜ‚ü© := order36_c4_c9Action_eq ŌÜ
  rw [hŌÜ]
  rcases order36_c4_unit_character_cases Ōá with hŌá | hŌá
  ¬∑ left
    rw [hŌá]
    exact order36_c9Action_one
  ¬∑ right
    rw [hŌá]

/-- The quotient map `C‚āā ‚Üí (ZMod 9)ň£` sending the generator to `-1`. -/
noncomputable abbrev order36_c2UnitHom : CyclicRep 2 ‚Üí* (ZMod 9)ň£ :=
  powHom (p := 9) (q := 2) (-1 : (ZMod 9)ň£) (by decide)

@[simp]
theorem order36_c2UnitHom_gen :
    order36_c2UnitHom (Multiplicative.ofAdd (1 : ZMod 2)) =
      (-1 : (ZMod 9)ň£) := by
  decide

theorem order36_c9Action_c2UnitHom_eq_invActionHom :
    order36_c9Action order36_c2UnitHom = invActionHom order36_C9 := by
  apply MonoidHom.ext
  intro h
  rcases multiplicative_zmod_two_cases h with rfl | rfl
  ¬∑ simp [order36_c9Action, invActionHom]
  ¬∑ change unitAutHom (order36_c2UnitHom (Multiplicative.ofAdd (1 : ZMod 2))) =
      invActionHom order36_C9 (Multiplicative.ofAdd (1 : ZMod 2))
    rw [order36_c2UnitHom_gen, invActionHom_ofAdd_one]
    ext x
    obtain ‚ü®m, rfl‚ü© := Multiplicative.ofAdd.surjective x
    simp [unitAutHom_apply, invAut_apply]

noncomputable abbrev order36_chiV4_fst : order36_V4 ‚Üí* (ZMod 9)ň£ :=
  order36_c2UnitHom.comp (MonoidHom.fst (CyclicRep 2) (CyclicRep 2))

noncomputable abbrev order36_chiV4_snd : order36_V4 ‚Üí* (ZMod 9)ň£ :=
  order36_c2UnitHom.comp (MonoidHom.snd (CyclicRep 2) (CyclicRep 2))

noncomputable abbrev order36_chiV4_prod : order36_V4 ‚Üí* (ZMod 9)ň£ :=
  order36_chiV4_fst * order36_chiV4_snd

/-- Homomorphisms out of `V‚āĄ = C‚āā √ó C‚āā` are determined by the two standard generators. -/
theorem order36_v4_hom_ext {M : Type*} [Group M] {Ōá Ōą : order36_V4 ‚Üí* M}
    (h1 : Ōá (Multiplicative.ofAdd (1 : ZMod 2), 1) =
      Ōą (Multiplicative.ofAdd (1 : ZMod 2), 1))
    (h2 : Ōá (1, Multiplicative.ofAdd (1 : ZMod 2)) =
      Ōą (1, Multiplicative.ofAdd (1 : ZMod 2))) :
    Ōá = Ōą := by
  apply MonoidHom.ext
  rintro ‚ü®x1, x2‚ü©
  obtain ‚ü®a, rfl‚ü© := Multiplicative.ofAdd.surjective x1
  obtain ‚ü®b, rfl‚ü© := Multiplicative.ofAdd.surjective x2
  let g1 : order36_V4 := (Multiplicative.ofAdd (1 : ZMod 2), 1)
  let g2 : order36_V4 := (1, Multiplicative.ofAdd (1 : ZMod 2))
  have ha : Multiplicative.ofAdd a = (Multiplicative.ofAdd (1 : ZMod 2)) ^ a.val := by
    calc
      Multiplicative.ofAdd a = Multiplicative.ofAdd ((a.val : ZMod 2)) := by
        rw [ZMod.natCast_zmod_val]
      _ = Multiplicative.ofAdd (a.val ‚ÄĘ (1 : ZMod 2)) := by simp
      _ = (Multiplicative.ofAdd (1 : ZMod 2)) ^ a.val := by rw [ofAdd_nsmul]
  have hb : Multiplicative.ofAdd b = (Multiplicative.ofAdd (1 : ZMod 2)) ^ b.val := by
    calc
      Multiplicative.ofAdd b = Multiplicative.ofAdd ((b.val : ZMod 2)) := by
        rw [ZMod.natCast_zmod_val]
      _ = Multiplicative.ofAdd (b.val ‚ÄĘ (1 : ZMod 2)) := by simp
      _ = (Multiplicative.ofAdd (1 : ZMod 2)) ^ b.val := by rw [ofAdd_nsmul]
  have hx : (Multiplicative.ofAdd a, Multiplicative.ofAdd b) = g1 ^ a.val * g2 ^ b.val := by
    simp [g1, g2, Prod.pow_mk, ha, hb]
  rw [hx, map_mul, map_mul, map_pow, map_pow, map_pow, map_pow, h1, h2]

@[simp]
theorem order36_chiV4_fst_g1 :
    order36_chiV4_fst (Multiplicative.ofAdd (1 : ZMod 2), 1) =
      (-1 : (ZMod 9)ň£) := by
  decide

@[simp]
theorem order36_chiV4_fst_g2 :
    order36_chiV4_fst (1, Multiplicative.ofAdd (1 : ZMod 2)) = 1 := by
  decide

@[simp]
theorem order36_chiV4_snd_g1 :
    order36_chiV4_snd (Multiplicative.ofAdd (1 : ZMod 2), 1) = 1 := by
  decide

@[simp]
theorem order36_chiV4_snd_g2 :
    order36_chiV4_snd (1, Multiplicative.ofAdd (1 : ZMod 2)) =
      (-1 : (ZMod 9)ň£) := by
  decide

@[simp]
theorem order36_chiV4_prod_g1 :
    order36_chiV4_prod (Multiplicative.ofAdd (1 : ZMod 2), 1) =
      (-1 : (ZMod 9)ň£) := by
  decide

@[simp]
theorem order36_chiV4_prod_g2 :
    order36_chiV4_prod (1, Multiplicative.ofAdd (1 : ZMod 2)) =
      (-1 : (ZMod 9)ň£) := by
  decide

theorem order36_v4_unit_character_cases (Ōá : order36_V4 ‚Üí* (ZMod 9)ň£) :
    Ōá = 1 ‚ą® Ōá = order36_chiV4_fst ‚ą® Ōá = order36_chiV4_snd ‚ą®
      Ōá = order36_chiV4_prod := by
  let g1 : order36_V4 := (Multiplicative.ofAdd (1 : ZMod 2), 1)
  let g2 : order36_V4 := (1, Multiplicative.ofAdd (1 : ZMod 2))
  have hsq1 : Ōá g1 ^ 2 = 1 := by
    rw [‚Üź map_pow, show g1 ^ 2 = 1 by decide, map_one]
  have hsq2 : Ōá g2 ^ 2 = 1 := by
    rw [‚Üź map_pow, show g2 ^ 2 = 1 by decide, map_one]
  rcases order36_unit_sq_eq_one_cases (Ōá g1) hsq1 with h1 | h1 <;>
    rcases order36_unit_sq_eq_one_cases (Ōá g2) hsq2 with h2 | h2
  ¬∑ left
    apply order36_v4_hom_ext <;>
      simp [g1, g2, h1, h2]
  ¬∑ right
    right
    left
    apply order36_v4_hom_ext <;>
      simp [g1, g2, h1, h2]
  ¬∑ right
    left
    apply order36_v4_hom_ext <;>
      simp [g1, g2, h1, h2]
  ¬∑ right
    right
    right
    apply order36_v4_hom_ext <;>
      simp [g1, g2, h1, h2]

/-- Every action `V‚āĄ ‚Üí Aut(C‚āČ)` is induced by a unit-valued character. -/
theorem order36_v4_c9Action_eq (ŌÜ : order36_V4 ‚Üí* MulAut order36_C9) :
    ‚ąÉ Ōá : order36_V4 ‚Üí* (ZMod 9)ň£, ŌÜ = order36_c9Action Ōá := by
  let g1 : order36_V4 := (Multiplicative.ofAdd (1 : ZMod 2), 1)
  let g2 : order36_V4 := (1, Multiplicative.ofAdd (1 : ZMod 2))
  obtain ‚ü®u, huŌÜ‚ü© := order36_mulAut_c9_eq_unitAutHom (ŌÜ g1)
  obtain ‚ü®v, hvŌÜ‚ü© := order36_mulAut_c9_eq_unitAutHom (ŌÜ g2)
  have hg1sq : g1 ^ 2 = 1 := by decide
  have hg2sq : g2 ^ 2 = 1 := by decide
  have hŌÜg1sq : (ŌÜ g1) ^ 2 = 1 := by rw [‚Üź map_pow, hg1sq, map_one]
  have hŌÜg2sq : (ŌÜ g2) ^ 2 = 1 := by rw [‚Üź map_pow, hg2sq, map_one]
  have hu2 : u ^ 2 = 1 := by
    apply order36_unitAutHom_injective
    rw [map_pow, ‚Üź huŌÜ, hŌÜg1sq]
    exact (map_one (unitAutHom (p := 9))).symm
  have hv2 : v ^ 2 = 1 := by
    apply order36_unitAutHom_injective
    rw [map_pow, ‚Üź hvŌÜ, hŌÜg2sq]
    exact (map_one (unitAutHom (p := 9))).symm
  let Ōá1 : order36_V4 ‚Üí* (ZMod 9)ň£ :=
    (powHom (p := 9) (q := 2) u hu2).comp (MonoidHom.fst (CyclicRep 2) (CyclicRep 2))
  let Ōá2 : order36_V4 ‚Üí* (ZMod 9)ň£ :=
    (powHom (p := 9) (q := 2) v hv2).comp (MonoidHom.snd (CyclicRep 2) (CyclicRep 2))
  refine ‚ü®Ōá1 * Ōá2, ?_‚ü©
  apply order36_v4_hom_ext
  ¬∑ rw [huŌÜ]
    change unitAutHom u = unitAutHom ((Ōá1 * Ōá2) g1)
    change unitAutHom u = unitAutHom (u ^ (1 : ZMod 2).val * v ^ (0 : ZMod 2).val)
    rw [show (1 : ZMod 2).val = 1 by decide, show (0 : ZMod 2).val = 0 by decide]
    simp
  ¬∑ rw [hvŌÜ]
    change unitAutHom v = unitAutHom ((Ōá1 * Ōá2) g2)
    change unitAutHom v = unitAutHom (u ^ (0 : ZMod 2).val * v ^ (1 : ZMod 2).val)
    rw [show (1 : ZMod 2).val = 1 by decide, show (0 : ZMod 2).val = 0 by decide]
    simp

theorem order36_v4_c9Action_cases (ŌÜ : order36_V4 ‚Üí* MulAut order36_C9) :
    ŌÜ = 1 ‚ą® ŌÜ = order36_c9Action order36_chiV4_fst ‚ą®
      ŌÜ = order36_c9Action order36_chiV4_snd ‚ą®
        ŌÜ = order36_c9Action order36_chiV4_prod := by
  obtain ‚ü®Ōá, hŌÜ‚ü© := order36_v4_c9Action_eq ŌÜ
  rw [hŌÜ]
  rcases order36_v4_unit_character_cases Ōá with hŌá | hŌá | hŌá | hŌá
  ¬∑ left
    rw [hŌá]
    exact order36_c9Action_one
  ¬∑ right
    left
    rw [hŌá]
  ¬∑ right
    right
    left
    rw [hŌá]
  ¬∑ right
    right
    right
    rw [hŌá]

theorem order36_c2_mul_self (x : CyclicRep 2) : x * x = 1 := by
  decide +revert

/-- Swap the two factors of `V‚āĄ = C‚āā √ó C‚āā`. -/
noncomputable def order36_V4_swap : order36_V4 ‚ČÉ* order36_V4 where
  toFun x := (x.2, x.1)
  invFun x := (x.2, x.1)
  left_inv x := by cases x; rfl
  right_inv x := by cases x; rfl
  map_mul' x y := by rfl

/-- The shear `(x, y) ‚Ü¶ (x, xy)` of `V‚āĄ = C‚āā √ó C‚āā`. -/
noncomputable def order36_V4_shear : order36_V4 ‚ČÉ* order36_V4 where
  toFun x := (x.1, x.1 * x.2)
  invFun x := (x.1, x.1 * x.2)
  left_inv x := by
    ext
    ¬∑ rfl
    ¬∑ change x.1 * (x.1 * x.2) = x.2
      rw [‚Üź mul_assoc, order36_c2_mul_self x.1, one_mul]
  right_inv x := by
    ext
    ¬∑ rfl
    ¬∑ change x.1 * (x.1 * x.2) = x.2
      rw [‚Üź mul_assoc, order36_c2_mul_self x.1, one_mul]
  map_mul' x y := by ext <;> simp [mul_comm, mul_left_comm]

noncomputable def order36_V4_toProd : order36_V4 ‚ČÉ* order36_V4 :=
  order36_V4_shear.trans order36_V4_swap

theorem order36_chiV4_fst_comp_swap :
    order36_chiV4_fst.comp order36_V4_swap.toMonoidHom = order36_chiV4_snd := by
  apply order36_v4_hom_ext <;> decide

theorem order36_chiV4_fst_comp_toProd :
